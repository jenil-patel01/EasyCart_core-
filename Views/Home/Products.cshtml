@model List<eays.Models.Product>
@{
    var categories = ViewBag.Categories as List<eays.Models.Category> ?? new List<eays.Models.Category>();
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentCategory = ViewBag.CurrentCategory as int?;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .shop-page { background: #f8fafc; min-height: 100vh; }

    /* ===== SEARCH BAR ===== */
    .shop-topbar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 32px 0 28px;
    }

    .shop-topbar h2 {
        color: #fff;
        font-weight: 800;
        font-size: 26px;
        margin-bottom: 16px;
    }

    .search-wrap {
        position: relative;
        max-width: 520px;
    }

    .search-wrap input {
        width: 100%;
        padding: 13px 20px 13px 48px;
        border-radius: 14px;
        border: none;
        font-size: 15px;
        font-weight: 500;
        background: rgba(255,255,255,.95);
        color: #2d3436;
        outline: none;
        box-shadow: 0 4px 20px rgba(0,0,0,.12);
        transition: box-shadow .2s;
    }

    .search-wrap input:focus {
        box-shadow: 0 6px 28px rgba(0,0,0,.18);
    }

    .search-wrap input::placeholder { color: #b2bec3; }

    .search-wrap .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 16px;
    }

    .search-wrap .search-btn {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 18px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: all .2s;
    }

    .search-wrap .search-btn:hover {
        transform: translateY(-50%) translateY(-1px);
        box-shadow: 0 4px 12px rgba(102,126,234,.4);
    }

    /* ===== SIDEBAR ===== */
    .cat-sidebar {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,.05);
        border: 1px solid #f1f2f6;
        position: sticky;
        top: 90px;
    }

    .cat-sidebar h5 {
        font-weight: 700;
        font-size: 15px;
        color: #2d3436;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .cat-sidebar h5 i { color: #667eea; }

    .cat-list { list-style: none; padding: 0; margin: 0; }

    .cat-list li { margin-bottom: 4px; }

    .cat-list a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        color: #636e72;
        font-weight: 500;
        font-size: 14px;
        transition: all .2s;
    }

    .cat-list a:hover {
        background: #f0ebff;
        color: #667eea;
    }

    .cat-list a.active {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        box-shadow: 0 4px 14px rgba(102,126,234,.25);
    }

    .cat-list a .cat-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        background: #f8f9fa;
        color: #667eea;
        flex-shrink: 0;
        transition: all .2s;
    }

    .cat-list a.active .cat-icon {
        background: rgba(255,255,255,.2);
        color: #fff;
    }

    .cat-list a:hover .cat-icon {
        background: #e8e0ff;
    }

    .cat-count {
        margin-left: auto;
        background: #f1f2f6;
        color: #636e72;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
    }

    .cat-list a.active .cat-count {
        background: rgba(255,255,255,.2);
        color: #fff;
    }

    /* ===== PRODUCT GRID ===== */
    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .results-header h5 {
        font-weight: 700;
        font-size: 16px;
        color: #2d3436;
        margin: 0;
    }

    .results-count {
        color: #b2bec3;
        font-size: 13px;
        font-weight: 600;
    }

    .product-card {
        border-radius: 16px;
        background: #fff;
        overflow: hidden;
        border: 1px solid #f1f2f6;
        transition: all .25s cubic-bezier(.4,0,.2,1);
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 14px 35px rgba(0,0,0,.08);
    }

    .product-card:hover::after {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 3px;
        background: linear-gradient(90deg, #667eea, #764ba2);
    }

    .product-img-wrap {
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        overflow: hidden;
        position: relative;
    }

    .product-img-wrap img {
        max-height: 150px;
        max-width: 90%;
        object-fit: contain;
        transition: transform .35s ease;
    }

    .product-card:hover .product-img-wrap img {
        transform: scale(1.08);
    }

    .product-cat-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(102,126,234,.9);
        color: #fff;
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .3px;
    }

    .wishlist-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        color: #e84393;
        transition: all .2s;
    }

    .wishlist-btn:hover {
        background: #fee2e2;
        transform: scale(1.1);
    }

    .product-body {
        padding: 16px;
        text-align: center;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .product-name {
        font-weight: 600;
        font-size: 14px;
        color: #2d3436;
        margin-bottom: 6px;
    }

    .product-price {
        font-weight: 700;
        color: #667eea;
        font-size: 17px;
        margin-bottom: 12px;
    }

    .product-actions {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .btn-view-product {
        display: block;
        padding: 8px;
        border: 2px solid #f1f2f6;
        border-radius: 10px;
        text-decoration: none;
        color: #636e72;
        font-weight: 600;
        font-size: 13px;
        transition: all .2s;
        text-align: center;
    }

    .btn-view-product:hover {
        border-color: #667eea;
        color: #667eea;
    }

    .btn-add-cart {
        display: block;
        padding: 9px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        text-align: center;
        transition: all .2s;
    }

    .btn-add-cart:hover {
        color: #fff;
        box-shadow: 0 6px 16px rgba(102,126,234,.3);
        transform: translateY(-1px);
    }

    /* Stock badge */
    .stock-badge {
        position: absolute;
        bottom: 10px;
        right: 10px;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
    }

    .stock-in { background: #d4edda; color: #155724; }
    .stock-out { background: #f8d7da; color: #721c24; }

    /* Empty */
    .shop-empty {
        text-align: center;
        padding: 60px 20px;
        color: #b2bec3;
    }

    .shop-empty i {
        font-size: 48px;
        display: block;
        margin-bottom: 14px;
        color: #dfe6e9;
    }

    .clear-filters {
        display: inline-block;
        margin-top: 10px;
        color: #667eea;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

    .clear-filters:hover { text-decoration: underline; }
</style>

<div class="shop-page">

    <!-- ===== SEARCH BAR ===== -->
    <div class="shop-topbar">
        <div class="container">
            <h2><i class="fa fa-store me-2"></i>Shop Products</h2>
            <form method="get" asp-controller="Home" asp-action="Products">
                @if (currentCategory.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategory" />
                }
                <div class="search-wrap">
                    <i class="fa fa-search search-icon"></i>
                    <input type="text" name="search" value="@currentSearch"
                           placeholder="Search products by name..." />
                    <button type="submit" class="search-btn">
                        <i class="fa fa-search me-1"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ===== CONTENT ===== -->
    <div class="container py-4">
        <div class="row g-4">

            <!-- SIDEBAR -->
            <div class="col-lg-3">
                <div class="cat-sidebar">
                    <h5><i class="fa fa-tags"></i> Categories</h5>
                    <ul class="cat-list">
                        <li>
                            <a href="/Home/Products@(string.IsNullOrEmpty(currentSearch) ? "" : "?search=" + currentSearch)"
                               class="@(currentCategory == null ? "active" : "")">
                                <span class="cat-icon"><i class="fa fa-border-all"></i></span>
                                All Products
                                <span class="cat-count">@Model.Count</span>
                            </a>
                        </li>
                        @foreach (var cat in categories)
                        {
                            var catProductCount = Model.Count(p => p.CategoryId == cat.Id);
                            var isActive = currentCategory == cat.Id;
                            <li>
                                <a href="/Home/Products?categoryId=@cat.Id@(string.IsNullOrEmpty(currentSearch) ? "" : "&search=" + currentSearch)"
                                   class="@(isActive ? "active" : "")">
                                    <span class="cat-icon">
                                        <i class="@(cat.Icon ?? "fa fa-tag")"></i>
                                    </span>
                                    @cat.Name
                                    <span class="cat-count">@catProductCount</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- PRODUCTS GRID -->
            <div class="col-lg-9">

                <div class="results-header">
                    <h5>
                        @if (currentCategory.HasValue)
                        {
                            var activeCat = categories.FirstOrDefault(c => c.Id == currentCategory);
                            @(activeCat?.Name ?? "Products")
                        }
                        else
                        {
                            <text>All Products</text>
                        }
                        @if (!string.IsNullOrEmpty(currentSearch))
                        {
                            <span style="font-weight:400;color:#b2bec3;"> — "@currentSearch"</span>
                        }
                    </h5>
                    <span class="results-count">@Model.Count result(s)</span>
                </div>

                @if (Model.Any())
                {
                    <div class="row g-3">
                        @foreach (var p in Model)
                        {
                            <div class="col-sm-6 col-md-4">
                                <div class="product-card">
                                    <div class="product-img-wrap">
                                        @if (p.Category != null)
                                        {
                                            <span class="product-cat-badge">@p.Category.Name</span>
                                        }

                                        <a asp-controller="Wishlist" asp-action="Add" asp-route-productId="@p.Id"
                                           class="wishlist-btn">
                                            <i class="fa fa-heart"></i>
                                        </a>

                                        @if (p.Stock > 0)
                                        {
                                            <span class="stock-badge stock-in">In Stock</span>
                                        }
                                        else
                                        {
                                            <span class="stock-badge stock-out">Out of Stock</span>
                                        }

                                        <img src="@p.ImageUrl" alt="@p.Name" />
                                    </div>

                                    <div class="product-body">
                                        <div class="product-name">@p.Name</div>
                                        <div class="product-price">$@p.Price.ToString("N2")</div>

                                        <div class="product-actions">
                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id"
                                               class="btn-view-product">
                                                <i class="fa fa-eye me-1"></i> View Details
                                            </a>
                                            @if (p.Stock > 0)
                                            {
                                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@p.Id"
                                                   class="btn-add-cart">
                                                    <i class="fa fa-cart-plus me-1"></i> Add to Cart
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="btn-add-cart" style="opacity:.4;pointer-events:none;cursor:not-allowed;">
                                                    <i class="fa fa-ban me-1"></i> Out of Stock
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="shop-empty">
                        <i class="fa fa-search"></i>
                        <h6 class="fw-bold" style="color:#636e72;">No products found</h6>
                        <p style="font-size:14px;">Try a different search or category.</p>
                        <a href="/Home/Products" class="clear-filters">
                            <i class="fa fa-arrow-left me-1"></i> Clear all filters
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</div>