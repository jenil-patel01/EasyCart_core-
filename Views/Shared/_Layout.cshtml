<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyCart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/user.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- ===== HEADER ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold" href="/">🛒 EasyCart</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">

                    <!-- Left -->
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/About">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Products">Products</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Contact">Contact</a></li>
                    </ul>

                    <!-- Right -->
                    <ul class="navbar-nav align-items-lg-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" href="/orders">
                                <i class="fa fa-box me-1"></i> My Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                                <i class="fa fa-heart me-1" style="color:#e84393;"></i> Wishlist (@(ViewBag.WishlistCount ?? 0))
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa fa-cart-shopping me-1" style="color:#667eea;"></i> Cart (@(ViewBag.CartCount ?? 0))
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- PROFILE AVATAR DROPDOWN -->
                            <li class="nav-item dropdown nav-profile-dropdown ms-lg-2">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 p-0"
                                   href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="nav-profile-avatar">
                                        @(User.Identity.Name != null && User.Identity.Name.Length > 0
                                            ? User.Identity.Name[0].ToString().ToUpper()
                                            : "U")
                                    </span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <div class="dropdown-header">
                                            <div class="profile-name">@User.Identity.Name</div>
                                            <div class="profile-email">Signed in</div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fa fa-user"></i> My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/orders">
                                            <i class="fa fa-bag-shopping"></i> My Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Wishlist" asp-action="Index">
                                            <i class="fa fa-heart"></i> Wishlist
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="fa fa-right-from-bracket"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="btn-nav-login" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-nav-register" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function setCartCount(count) {
            const el = document.getElementById('cart-count');
            if (el) el.textContent = count;
        }

        (function () {
            var success = '@(TempData["SuccessMessage"] ?? "")';
            if (success) {
                alert(success);
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
<footer class="site-footer">
    <div class="container">
        <div class="row">

            <!-- Brand -->
            <div class="col-lg-4 col-md-6 mb-4">
                <h4 class="footer-logo">EasyCart</h4>
                <p class="footer-text">
                    Your trusted online shopping destination for quality products,
                    fast delivery, and secure payments.
                </p>
            </div>

            <!-- Links -->
            <div class="col-lg-2 col-md-6 mb-4">
                <h5 class="footer-title">Shop</h5>
                <ul class="footer-links">
                    <li><a asp-controller="Products" asp-action="Index">Products</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Cart</a></li>
                    <li><a asp-controller="Wishlist" asp-action="Index">Wishlist</a></li>
                    <li><a asp-controller="Orders" asp-action="Index">My Orders</a></li>
                </ul>
            </div>

            <!-- Company -->
            <div class="col-lg-2 col-md-6 mb-4">
                <h5 class="footer-title">Company</h5>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About">About</a></li>
                    <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                    <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-lg-4 col-md-6 mb-4">
                <h5 class="footer-title">Contact</h5>
                <p class="footer-text">
                    Rajkot, Gujarat, India <br>
                    support@easycart.com <br>
                    +91 98765 43210
                </p>
            </div>

        </div>

        <hr class="footer-divider">

        <div class="footer-bottom">
            <p>© 2026 EasyCart. All rights reserved.</p>
        </div>
    </div>
</footer>
</html>