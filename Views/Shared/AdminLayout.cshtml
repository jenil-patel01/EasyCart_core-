<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Admin</title>

    <link rel="stylesheet" href="/Admincss/StyleSheet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body>
    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo">🛒 EasyCart</div>

            <nav>
                <a href="/Admin"><i class="fa fa-home"></i> Dashboard</a>
                <a href="/Admin/Products"><i class="fa fa-box"></i> Products</a>
                <a href="/Admin/Categories"><i class="fa fa-tags"></i> Categories</a>
                <a href="/Admin/Users"><i class="fa fa-users"></i> Users</a>
                <a href="/Admin/Orders"><i class="fa fa-bag-shopping"></i> Orders</a>
                <a href="/Account/Logout"><i class="fa fa-right-from-bracket"></i> Logout</a>
                
            </nav>
        </aside>

        <!-- MAIN -->
        <div class="main">

            <!-- TOPBAR -->
            <header class="topbar">
                <div class="search">
                    <input placeholder="Search..." />
                </div>

                <div class="user">
                    <img src="https://i.pravatar.cc/40" />
                    <span>Admin</span>
                </div>
            </header>

            <!-- PAGE -->
            <div class="content">
                @RenderBody()
            </div>

        </div>
    </div>
</body>
</html>