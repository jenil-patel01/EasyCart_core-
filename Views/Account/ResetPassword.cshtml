@model eays.Models.ResetPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reset Password - EasyCart</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/user.min.css" asp-append-version="true" />
</head>

<body class="auth-body bg-gradient">
    <div class="reset-card">
        <div class="icon-wrapper">
            <i class="fa fa-lock"></i>
        </div>

        <div class="title">Reset Password</div>
        <div class="subtitle">
            Create a new password for your account
        </div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label">
                    <i class="fa fa-key me-1"></i> New Password
                </label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter new password" autofocus />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">
                    <i class="fa fa-shield-halved me-1"></i> Confirm Password
                </label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="password-requirements">
                <strong><i class="fa fa-info-circle me-1"></i>Password Requirements:</strong>
                <ul>
                    <li>Minimum 6 characters long</li>
                    <li>Both passwords must match</li>
                </ul>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fa fa-check-circle me-2"></i>
                Reset Password
            </button>
        </form>

        <div class="back-link">
            <a href="/Account/Login">
                <i class="fa fa-arrow-left me-1"></i>
                Back to Login
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
