@model List<eays.Models.Product>
@{
    var categories = ViewBag.Categories as List<eays.Models.Category> ?? new List<eays.Models.Category>();
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentCategory = ViewBag.CurrentCategory as int?;
    var wishlistIds = ViewBag.WishlistProductIds as List<int> ?? new List<int>();
}

<div class="shop-page">

    <!-- ===== SEARCH BAR ===== -->
    <div class="shop-topbar">
        <div class="container">
            <h2><i class="fa fa-store me-2"></i>Shop Products</h2>
            <form method="get" asp-controller="Home" asp-action="Products">
                @if (currentCategory.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategory" />
                }
                <div class="search-wrap">
                    <i class="fa fa-search search-icon"></i>
                    <input type="text" name="search" value="@currentSearch"
                           placeholder="Search products by name..." />
                    <button type="submit" class="search-btn">
                        <i class="fa fa-search me-1"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ===== CONTENT ===== -->
    <div class="container py-4">
        <div class="row g-4">

            <!-- SIDEBAR -->
            <div class="col-lg-3">
                <div class="cat-sidebar">
                    <h5><i class="fa fa-tags"></i> Categories</h5>
                    <ul class="cat-list">
                        <li>
                            <a href="/Home/Products@(string.IsNullOrEmpty(currentSearch) ? "" : "?search=" + currentSearch)"
                               class="@(currentCategory == null ? "active" : "")">
                                <span class="cat-icon"><i class="fa fa-border-all"></i></span>
                                All Products
                                <span class="cat-count">@Model.Count</span>
                            </a>
                        </li>
                        @foreach (var cat in categories)
                        {
                            var catProductCount = Model.Count(p => p.CategoryId == cat.Id);
                            var isActive = currentCategory == cat.Id;
                            <li>
                                <a href="/Home/Products?categoryId=@cat.Id@(string.IsNullOrEmpty(currentSearch) ? "" : "&search=" + currentSearch)"
                                   class="@(isActive ? "active" : "")">
                                    <span class="cat-icon">
                                        <i class="@(cat.Icon ?? "fa fa-tag")"></i>
                                    </span>
                                    @cat.Name
                                    <span class="cat-count">@catProductCount</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- PRODUCTS GRID -->
            <div class="col-lg-9">

                <div class="results-header">
                    <h5>
                        @if (currentCategory.HasValue)
                        {
                            var activeCat = categories.FirstOrDefault(c => c.Id == currentCategory);
                            @(activeCat?.Name ?? "Products")
                        }
                        else
                        {
                            <text>All Products</text>
                        }
                        @if (!string.IsNullOrEmpty(currentSearch))
                        {
                            <span style="font-weight:400;color:#b2bec3;"> — "@currentSearch"</span>
                        }
                    </h5>
                    <span class="results-count">@Model.Count result(s)</span>
                </div>

                @if (Model.Any())
                {
                    <div class="row g-3">
                        @foreach (var p in Model)
                        {
                            <div class="col-sm-6 col-md-4">
                                <div class="product-card">
                                    <div class="product-img-wrap">
                                        @if (p.Category != null)
                                        {
                                            <span class="product-cat-badge">@p.Category.Name</span>
                                        }

                                        <a asp-controller="Wishlist" asp-action="Add" asp-route-productId="@p.Id"
                                           class="wishlist-btn @(wishlistIds.Contains(p.Id) ? "active" : "")">
                                            <i class="@(wishlistIds.Contains(p.Id) ? "fa-solid" : "fa-regular") fa-heart"></i>
                                        </a>

                                        @if (p.Stock > 0)
                                        {
                                            <span class="stock-badge stock-in">In Stock</span>
                                        }
                                        else
                                        {
                                            <span class="stock-badge stock-out">Out of Stock</span>
                                        }

                                        <img src="@p.ImageUrl" alt="@p.Name" />
                                    </div>

                                    <div class="product-body">
                                        <div class="product-name">@p.Name</div>
                                        <div class="product-price">&#8377;@p.Price.ToString("N2")</div>

                                        <div class="product-actions">
                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id"
                                               class="btn-view-product">
                                                <i class="fa fa-eye me-1"></i> View Details
                                            </a>
                                            @if (p.Stock > 0)
                                            {
                                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@p.Id"
                                                   class="btn-add-cart">
                                                    <i class="fa fa-cart-plus me-1"></i> Add to Cart
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="btn-add-cart" style="opacity:.4;pointer-events:none;cursor:not-allowed;">
                                                    <i class="fa fa-ban me-1"></i> Out of Stock
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="shop-empty">
                        <i class="fa fa-search"></i>
                        <h6 class="fw-bold" style="color:#636e72;">No products found</h6>
                        <p style="font-size:14px;">Try a different search or category.</p>
                        <a href="/Home/Products" class="clear-filters">
                            <i class="fa fa-arrow-left me-1"></i> Clear all filters
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</div>