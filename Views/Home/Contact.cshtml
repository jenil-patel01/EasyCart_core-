@model eays.Models.ContactViewModel
@{
    ViewData["Title"] = "Contact Us";
}

<div class="contact-page">

    <!-- ===== HERO ===== -->
    <section class="contact-hero">
        <h1><i class="fa fa-envelope me-2"></i>Contact Us</h1>
        <p>Have a question or feedback? We'd love to hear from you!</p>
    </section>

    <div class="container" style="max-width:1100px;">

        <!-- ===== INFO CARDS ===== -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon" style="background:linear-gradient(135deg,#667eea,#764ba2);">
                        <i class="fa fa-location-dot"></i>
                    </div>
                    <h5>Our Address</h5>
                    <p>Rk University<br />Rajkot,Gujarat</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon" style="background:linear-gradient(135deg,#00b894,#00cec9);">
                        <i class="fa fa-phone"></i>
                    </div>
                    <h5>Call Us</h5>
                    <p>
                        <a href="tel:+12345678900">+1 234 567 8900</a><br />
                        Mon &#8211; Sat: 9AM &#8211; 9PM
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon" style="background:linear-gradient(135deg,#fdcb6e,#e17055);">
                        <i class="fa fa-envelope"></i>
                    </div>
                    <h5>Email Us</h5>
                    <p>
                        <a href="mailto:support@easycart.com">support&#64;easycart.com</a><br />
                        We reply within 24 hours
                    </p>
                </div>
            </div>
        </div>

        <!-- ===== FORM + MAP ===== -->
        <div class="row g-4 mb-5">

            <!-- FORM -->
            <div class="col-lg-7">
                <div class="contact-form-card">
                    <h3><i class="fa fa-paper-plane me-2" style="color:#667eea;"></i>Send us a Message</h3>
                    <p class="form-subtitle">Fill out the form below and we'll get back to you as soon as possible.</p>

                    @if (TempData["ContactSuccess"] != null)
                    {
                        <div class="contact-success">
                            <i class="fa fa-check-circle"></i> @TempData["ContactSuccess"]
                        </div>
                    }

                    <form asp-controller="Home" asp-action="Contact" method="post" class="contact-form">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Your Name</label>
                                <div class="input-icon-wrap">
                                    <i class="fa fa-user"></i>
                                    <input asp-for="Name" class="form-control" placeholder="John Doe" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <div class="input-icon-wrap">
                                    <i class="fa fa-envelope"></i>
                                    <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Subject</label>
                                <div class="input-icon-wrap">
                                    <i class="fa fa-tag"></i>
                                    <input asp-for="Subject" class="form-control" placeholder="How can we help?" />
                                </div>
                                <span asp-validation-for="Subject" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Message</label>
                                <textarea asp-for="Message" class="form-control" rows="5"
                                          placeholder="Tell us more about your question or feedback..."></textarea>
                                <span asp-validation-for="Message" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn-send">
                                    <i class="fa fa-paper-plane me-2"></i> Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- MAP + HOURS -->
            <div class="col-lg-5">
                <div class="map-card">
                    <div class="map-header">
                        <h3><i class="fa fa-map-location-dot me-2" style="color:#667eea;"></i>Find Us</h3>
                        <p>Visit our store or reach out online</p>

                        <ul class="hours-list">
                            <li>
                                <span><i class="fa fa-clock me-1" style="color:#b2bec3;"></i> Monday &#8211; Friday</span>
                                <span>9:00 AM &#8211; 9:00 PM</span>
                            </li>
                            <li>
                                <span><i class="fa fa-clock me-1" style="color:#b2bec3;"></i> Saturday</span>
                                <span>10:00 AM &#8211; 6:00 PM</span>
                            </li>
                            <li>
                                <span><i class="fa fa-clock me-1" style="color:#b2bec3;"></i> Sunday</span>
                                <span style="color:#e84393;">Closed</span>
                            </li>
                        </ul>
                    </div>
                    <div class="map-frame">
                        <iframe width="100%"
                                height="400"
                                style="border:0; border-radius:10px;"
                                src="https://www.google.com/maps?q=22.2404115,70.9004241&z=17&output=embed"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
