@model eays.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="profile-hero">
    <div class="container">

        <!-- HEADER -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-10">
                <div class="profile-header">
                    <div class="profile-header-body">
                        <div class="profile-avatar">
                            @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U")
                        </div>

                        <div class="profile-name">@Model.FullName</div>

                        <div class="profile-email-text">
                            <i class="fa fa-envelope me-1"></i> @Model.Email
                        </div>

                        <span class="profile-verified">
                            <i class="fa fa-check-circle me-1"></i> Verified Member
                        </span>
                    </div>
                </div>
            </div>
        </div>


        <!-- STATS -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-10">

                <div class="row g-3">

                    <!-- TOTAL ORDERS -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon purple">
                                <i class="fa fa-bag-shopping"></i>
                            </div>

                            <div class="stat-value">
                                @Model.TotalOrders
                            </div>

                            <div class="stat-label">
                                Total Orders
                            </div>
                        </div>
                    </div>


                    <!-- TOTAL SPENT -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon green">
                                <i class="fa fa-indian-rupee-sign"></i>
                            </div>

                            <div class="stat-value">
                                &#8377;@Model.TotalSpent.ToString("N0")
                            </div>

                            <div class="stat-label">
                                Total Spent
                            </div>
                        </div>
                    </div>


                    <!-- CART COUNT -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon orange">
                                <i class="fa fa-cart-shopping"></i>
                            </div>

                            <div class="stat-value">
                                @Model.CartItemsCount
                            </div>

                            <div class="stat-label">
                                In Cart
                            </div>
                        </div>
                    </div>


                    <!-- WISHLIST COUNT -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon pink">
                                <i class="fa fa-heart"></i>
                            </div>

                            <div class="stat-value">
                                @Model.WishlistCount
                            </div>

                            <div class="stat-label">
                                Wishlist
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>


        <!-- RECENT ORDERS -->
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="glass-card">

                    <h5 class="mb-3">
                        <i class="fa fa-clock-rotate-left me-2"></i>
                        Recent Orders
                    </h5>

                    @if (Model.RecentOrders.Any())
                    {
                        <div class="table-responsive">

                            <table class="table table-hover">

                                <thead>
                                    <tr>
                                        <th>Order</th>
                                        <th>Date</th>
                                        <th>Items</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>

                                            <td>
                                                <strong>#@order.Id</strong>
                                            </td>

                                            <td>
                                                @order.OrderDate.ToString("MMM dd, yyyy")
                                            </td>

                                            <td>
                                                @(order.OrderItems?.Count ?? 0) items
                                            </td>

                                            <td>
                                                <strong>
                                                    &#8377;@order.TotalAmount.ToString("N2")
                                                </strong>
                                            </td>

                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">

                            <i class="fa fa-box-open fa-3x mb-3 text-muted"></i>

                            <h6>No orders yet</h6>

                            <a href="/Home/Products" class="btn btn-primary mt-2">
                                Browse Products
                            </a>

                        </div>
                    }

                </div>
            </div>
        </div>

    </div>
</div>