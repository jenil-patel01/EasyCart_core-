@model List<eays.Models.Order>
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0">Orders Management</h2>
    <span style="font-size:14px; color:#b2bec3; font-weight:600;">
        @Model.Count order(s)
    </span>
</div>

@if (TempData["OrderMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert"
         style="border-radius:10px; border:none; font-weight:600;">
        <i class="fa fa-check-circle me-1"></i> @TempData["OrderMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- FILTER TABS -->
<div class="filter-tabs">
    <a href="/Admin/Orders" class="filter-tab @(ViewBag.CurrentFilter == "All" ? "active" : "")">
        All <span class="badge">@(Model.Count)</span>
    </a>
    <a href="/Admin/Orders?status=Pending" class="filter-tab @(ViewBag.CurrentFilter == "Pending" ? "active" : "")">
        ?? Pending <span class="badge">@ViewBag.PendingCount</span>
    </a>
    <a href="/Admin/Orders?status=Processing" class="filter-tab @(ViewBag.CurrentFilter == "Processing" ? "active" : "")">
        ?? Processing <span class="badge">@ViewBag.ProcessingCount</span>
    </a>
    <a href="/Admin/Orders?status=Shipped" class="filter-tab @(ViewBag.CurrentFilter == "Shipped" ? "active" : "")">
        ?? Shipped <span class="badge">@ViewBag.ShippedCount</span>
    </a>
    <a href="/Admin/Orders?status=Delivered" class="filter-tab @(ViewBag.CurrentFilter == "Delivered" ? "active" : "")">
        ? Delivered <span class="badge">@ViewBag.DeliveredCount</span>
    </a>
    <a href="/Admin/Orders?status=Cancelled" class="filter-tab @(ViewBag.CurrentFilter == "Cancelled" ? "active" : "")">
        ? Cancelled <span class="badge">@ViewBag.CancelledCount</span>
    </a>
</div>

<!-- ORDERS TABLE -->
@if (Model.Any())
{
    <div class="orders-table">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Order</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><span class="order-id-badge">#@order.Id</span></td>
                        <td><strong>@order.FullName</strong></td>
                        <td style="color:#636e72; font-size:13px;">@order.Email</td>
                        <td style="font-size:13px;">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>@(order.OrderItems?.Count ?? 0)</td>
                        <td class="amount-text">&#8377;@order.TotalAmount.ToString("N2")</td>
                        <td>
                            <span class="status-pill status-@order.Status">@order.Status</span>
                        </td>
                        <td style="text-align:right;">
                            <a href="/Admin/OrderDetail/@order.Id" class="btn-detail me-1">
                                <i class="fa fa-eye"></i> View
                            </a>
                            <form asp-action="DeleteOrder" method="post" style="display:inline;"
                                  onsubmit="return confirm('Delete order #@order.Id?')">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn-del">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fa fa-box-open"></i>
        <h5 class="fw-bold" style="color:#636e72;">No orders found</h5>
        <p>Orders will appear here when customers place them.</p>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
