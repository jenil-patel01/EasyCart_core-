@model eays.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var relatedProducts = ViewBag.RelatedProducts as List<eays.Models.Product> ?? new List<eays.Models.Product>();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .detail-page { background: #f8fafc; min-height: 100vh; }

    /* ===== BREADCRUMB ===== */
    .detail-breadcrumb {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px 0;
    }

    .detail-breadcrumb a {
        color: rgba(255,255,255,.7);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: color .2s;
    }

    .detail-breadcrumb a:hover { color: #fff; }

    .detail-breadcrumb span {
        color: rgba(255,255,255,.5);
        margin: 0 8px;
        font-size: 12px;
    }

    .detail-breadcrumb .current {
        color: #fff;
        font-weight: 600;
        font-size: 13px;
    }

    /* ===== MAIN CARD ===== */
    .detail-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,.06);
        overflow: hidden;
        border: 1px solid #f1f2f6;
    }

    /* ===== IMAGE SECTION ===== */
    .detail-img-wrap {
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        padding: 30px;
        position: relative;
    }

    .detail-img-wrap img {
        max-height: 360px;
        max-width: 100%;
        object-fit: contain;
        transition: transform .4s ease;
    }

    .detail-img-wrap:hover img {
        transform: scale(1.05);
    }

    .detail-cat-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        padding: 5px 14px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .detail-stock-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        padding: 5px 14px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
    }

    .detail-stock-in {
        background: #d4edda;
        color: #155724;
    }

    .detail-stock-out {
        background: #f8d7da;
        color: #721c24;
    }

    .img-placeholder {
        width: 200px;
        height: 200px;
        border-radius: 20px;
        background: #f1f2f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #b2bec3;
        font-size: 60px;
    }

    /* ===== INFO SECTION ===== */
    .detail-info {
        padding: 36px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .detail-info .product-title {
        font-size: 28px;
        font-weight: 800;
        color: #2d3436;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .detail-info .product-category {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #667eea;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 18px;
    }

    .detail-info .product-category i { font-size: 12px; }

    .detail-info .product-price-box {
        background: linear-gradient(135deg, #f0ebff, #ede4ff);
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 22px;
        display: inline-flex;
        align-items: baseline;
        gap: 8px;
    }

    .detail-info .product-price-box .price-label {
        font-size: 12px;
        font-weight: 700;
        color: #636e72;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .detail-info .product-price-box .price-value {
        font-size: 32px;
        font-weight: 800;
        color: #667eea;
    }

    /* ===== META ROWS ===== */
    .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 24px;
    }

    .meta-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .meta-item .meta-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        color: #fff;
        flex-shrink: 0;
    }

    .meta-item .meta-label {
        font-size: 10px;
        color: #b2bec3;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .meta-item .meta-value {
        font-size: 14px;
        font-weight: 700;
        color: #2d3436;
    }

    /* ===== ACTION BUTTONS ===== */
    .detail-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-detail-cart {
        flex: 1;
        min-width: 180px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 28px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
        transition: all .25s;
    }

    .btn-detail-cart:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 28px rgba(102,126,234,.35);
        color: #fff;
    }

    .btn-detail-cart.disabled {
        opacity: .45;
        pointer-events: none;
        cursor: not-allowed;
    }

    .btn-detail-wishlist {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: #fff;
        color: #e84393;
        border: 2px solid #fee2e2;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
        transition: all .25s;
    }

    .btn-detail-wishlist:hover {
        background: #fee2e2;
        border-color: #e84393;
        transform: translateY(-2px);
        color: #e84393;
    }

    .btn-detail-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 14px 24px;
        background: #f1f2f6;
        color: #636e72;
        border-radius: 14px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all .2s;
    }

    .btn-detail-back:hover {
        background: #dfe6e9;
        color: #2d3436;
    }

    /* ===== RELATED PRODUCTS ===== */
    .related-section {
        margin-top: 40px;
    }

    .related-section h4 {
        font-weight: 800;
        font-size: 20px;
        color: #2d3436;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .related-section h4 i { color: #667eea; }

    .related-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #f1f2f6;
        transition: all .25s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .related-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
    }

    .related-card .r-img {
        height: 160px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .related-card .r-img img {
        max-height: 130px;
        max-width: 90%;
        object-fit: contain;
        transition: transform .3s;
    }

    .related-card:hover .r-img img { transform: scale(1.08); }

    .related-card .r-cat {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(102,126,234,.85);
        color: #fff;
        padding: 2px 8px;
        border-radius: 5px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .related-card .r-body {
        padding: 14px;
        text-align: center;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .related-card .r-name {
        font-weight: 600;
        font-size: 13px;
        color: #2d3436;
        margin-bottom: 4px;
    }

    .related-card .r-price {
        font-weight: 700;
        color: #667eea;
        font-size: 16px;
        margin-bottom: 10px;
    }

    .related-card .r-btn {
        margin-top: auto;
        display: block;
        padding: 8px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 12px;
        transition: all .2s;
        text-align: center;
    }

    .related-card .r-btn:hover {
        box-shadow: 0 4px 14px rgba(102,126,234,.3);
        color: #fff;
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .detail-info { padding: 24px; }
        .detail-info .product-title { font-size: 22px; }
        .detail-info .product-price-box .price-value { font-size: 26px; }
        .meta-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="detail-page">

    <!-- ===== BREADCRUMB ===== -->
    <div class="detail-breadcrumb">
        <div class="container">
            <a href="/"><i class="fa fa-home"></i> Home</a>
            <span><i class="fa fa-chevron-right"></i></span>
            <a href="/Home/Products">Products</a>
            @if (Model.Category != null)
            {
                <span><i class="fa fa-chevron-right"></i></span>
                <a href="/Home/Products?categoryId=@Model.CategoryId">@Model.Category.Name</a>
            }
            <span><i class="fa fa-chevron-right"></i></span>
            <span class="current">@Model.Name</span>
        </div>
    </div>

    <!-- ===== PRODUCT DETAIL ===== -->
    <div class="container py-4">
        <div class="detail-card">
            <div class="row g-0">

                <!-- IMAGE -->
                <div class="col-lg-6">
                    <div class="detail-img-wrap">
                        @if (Model.Category != null)
                        {
                            <span class="detail-cat-badge">
                                <i class="@(Model.Category.Icon ?? "fa fa-tag") me-1"></i> @Model.Category.Name
                            </span>
                        }

                        @if (Model.Stock > 0)
                        {
                            <span class="detail-stock-badge detail-stock-in">
                                <i class="fa fa-check-circle me-1"></i> In Stock (@Model.Stock)
                            </span>
                        }
                        else
                        {
                            <span class="detail-stock-badge detail-stock-out">
                                <i class="fa fa-times-circle me-1"></i> Out of Stock
                            </span>
                        }

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" />
                        }
                        else
                        {
                            <div class="img-placeholder">
                                <i class="fa fa-image"></i>
                            </div>
                        }
                    </div>
                </div>

                <!-- INFO -->
                <div class="col-lg-6">
                    <div class="detail-info">

                        <h1 class="product-title">@Model.Name</h1>

                        @if (Model.Category != null)
                        {
                            <div class="product-category">
                                <i class="@(Model.Category.Icon ?? "fa fa-tag")"></i>
                                @Model.Category.Name
                            </div>
                        }

                        <div class="product-price-box">
                            <span class="price-label">Price</span>
                            <span class="price-value">$@Model.Price.ToString("N2")</span>
                        </div>

                        <!-- META -->
                        <div class="meta-grid">
                            <div class="meta-item">
                                <div class="meta-icon" style="background:linear-gradient(135deg,#00b894,#00cec9);">
                                    <i class="fa fa-boxes-stacked"></i>
                                </div>
                                <div>
                                    <div class="meta-label">Stock</div>
                                    <div class="meta-value">
                                        @(Model.Stock > 0 ? Model.Stock + " units available" : "Out of stock")
                                    </div>
                                </div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon" style="background:linear-gradient(135deg,#667eea,#764ba2);">
                                    <i class="fa fa-tag"></i>
                                </div>
                                <div>
                                    <div class="meta-label">Category</div>
                                    <div class="meta-value">@(Model.Category?.Name ?? "Uncategorized")</div>
                                </div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon" style="background:linear-gradient(135deg,#fdcb6e,#e17055);">
                                    <i class="fa fa-truck-fast"></i>
                                </div>
                                <div>
                                    <div class="meta-label">Shipping</div>
                                    <div class="meta-value">Free Delivery</div>
                                </div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon" style="background:linear-gradient(135deg,#fd79a8,#e84393);">
                                    <i class="fa fa-shield-halved"></i>
                                </div>
                                <div>
                                    <div class="meta-label">Warranty</div>
                                    <div class="meta-value">1 Year Warranty</div>
                                </div>
                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="detail-actions">
                            @if (Model.Stock > 0)
                            {
                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id"
                                   class="btn-detail-cart">
                                    <i class="fa fa-cart-plus"></i> Add to Cart
                                </a>
                            }
                            else
                            {
                                <span class="btn-detail-cart disabled">
                                    <i class="fa fa-ban"></i> Out of Stock
                                </span>
                            }

                            <a asp-controller="Wishlist" asp-action="Add" asp-route-productId="@Model.Id"
                               class="btn-detail-wishlist">
                                <i class="fa fa-heart"></i> Wishlist
                            </a>

                            <a href="/Home/Products" class="btn-detail-back">
                                <i class="fa fa-arrow-left"></i> Back
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <!-- ===== RELATED PRODUCTS ===== -->
        @if (relatedProducts.Any())
        {
            <div class="related-section">
                <h4><i class="fa fa-sparkles"></i> You May Also Like</h4>

                <div class="row g-3">
                    @foreach (var rp in relatedProducts)
                    {
                        <div class="col-6 col-md-3">
                            <div class="related-card">
                                <div class="r-img">
                                    @if (rp.Category != null)
                                    {
                                        <span class="r-cat">@rp.Category.Name</span>
                                    }
                                    @if (!string.IsNullOrEmpty(rp.ImageUrl))
                                    {
                                        <img src="@rp.ImageUrl" alt="@rp.Name" />
                                    }
                                    else
                                    {
                                        <i class="fa fa-image" style="font-size:40px;color:#dfe6e9;"></i>
                                    }
                                </div>
                                <div class="r-body">
                                    <div class="r-name">@rp.Name</div>
                                    <div class="r-price">$@rp.Price.ToString("N2")</div>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@rp.Id" class="r-btn">
                                        <i class="fa fa-eye me-1"></i> View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
