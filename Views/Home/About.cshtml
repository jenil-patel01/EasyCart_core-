@{
    ViewData["Title"] = "About";
}

<div class="user-page">

    <!-- HERO -->
    <section class="about-hero">
        <h1>About EasyCart</h1>
        <p>Your trusted online shopping destination</p>
    </section>

    <!-- CONTENT -->
    <section class="about-content">

        <div class="about-section">
            <h2>Our Story</h2>
            <p>
                EasyCart was founded with a simple mission: to make online shopping easy,
                convenient, and affordable for everyone. We started as a small e-commerce
                platform and have grown to serve thousands of customers worldwide.
            </p>
            <p>
                Our commitment to excellence and customer satisfaction has made us one of
                the most trusted online retailers in the industry.
            </p>
        </div>

        <div class="about-section">
            <h2>Our Mission</h2>
            <p>
                To provide high-quality products at competitive prices while delivering
                exceptional customer service and a seamless shopping experience.
            </p>
        </div>

        <div class="about-section">
            <h2>Our Vision</h2>
            <p>
                To be the go-to online marketplace for electronics and accessories,
                known for quality, innovation, and customer-centric approach.
            </p>
        </div>

        <div class="about-section">
            <h2>Why Choose Us?</h2>
            <ul class="about-list">
                <li>✓ Wide selection of products</li>
                <li>✓ Competitive prices</li>
                <li>✓ Fast and secure checkout</li>
                <li>✓ Reliable shipping</li>
                <li>✓ Excellent customer support</li>
                <li>✓ Easy returns and exchanges</li>
                <li>✓ Regular deals and discounts</li>
                <li>✓ Secure payment options</li>
            </ul>
        </div>

        <div class="about-section">
            <h2>Contact Us</h2>
            <p>
                <strong>Email:</strong> support@easycart.com<br />
                <strong>Phone:</strong> 1-800-EASYCART<br />
                <strong>Address:</strong> 123 Commerce Street, Tech City, TC 12345
            </p>
        </div>

        <!-- STATS -->
        <div class="about-stats">
            <div class="stat-item">
                <h3>10K+</h3>
                <p>Products</p>
            </div>
            <div class="stat-item">
                <h3>50K+</h3>
                <p>Happy Customers</p>
            </div>
            <div class="stat-item">
                <h3>100+</h3>
                <p>Brands</p>
            </div>
            <div class="stat-item">
                <h3>24/7</h3>
                <p>Support</p>
            </div>
        </div>

    </section>
</div>