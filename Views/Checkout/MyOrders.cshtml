@model List<eays.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="orders-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <div class="d-flex align-items-center mb-4">
                    <h2 class="orders-title mb-0">
                        <i class="fa fa-bag-shopping"></i> My Orders
                    </h2>
                    <span class="orders-count">@Model.Count</span>
                </div>

                @if (Model.Any())
                {
                    <div class="d-flex flex-column gap-4">

                        @foreach (var order in Model)
                        {
                            // Determine step index for tracker
                            var statusSteps = new[] { "Pending", "Processing", "Shipped", "Delivered" };
                            var isCancelled = order.Status == "Cancelled";
                            var currentStep = Array.IndexOf(statusSteps, order.Status);
                            if (currentStep < 0 && !isCancelled) currentStep = 0;

                            <div class="order-card">
                                <!-- Header -->
                                <div class="order-card-header">
                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                        <span class="order-id">#@order.Id</span>
                                        <span class="order-date">
                                            <i class="fa fa-calendar-day"></i>
                                            @order.OrderDate.ToString("MMM dd, yyyy — hh:mm tt")
                                        </span>
                                        <span class="status-pill status-@order.Status">
                                            @if (order.Status == "Pending")
                                            {
                                                <i class="fa fa-clock"></i>
                                            }
                                            else if (order.Status == "Processing")
                                            {
                                                <i class="fa fa-gear"></i>
                                            }
                                            else if (order.Status == "Shipped")
                                            {
                                                <i class="fa fa-truck-fast"></i>
                                            }
                                            else if (order.Status == "Delivered")
                                            {
                                                <i class="fa fa-circle-check"></i>
                                            }
                                            else if (order.Status == "Cancelled")
                                            {
                                                <i class="fa fa-ban"></i>
                                            }
                                            @order.Status
                                        </span>
                                    </div>
                                    <div class="order-total-badge">&#8377;@order.TotalAmount.ToString("N2")</div>
                                </div>

                                <!-- Status Tracker -->
                                <div class="order-tracker">
                                    @if (isCancelled)
                                    {
                                        <!-- Cancelled: show a single cancelled state -->
                                        <div class="tracker-step done">
                                            <div class="tracker-dot"><i class="fa fa-check" style="font-size:12px;"></i></div>
                                            <div class="tracker-label">Ordered</div>
                                        </div>
                                        <div class="tracker-line-wrap cancelled-line">
                                            <div class="tracker-line-fill" style="width:100%;"></div>
                                        </div>
                                        <div class="tracker-step cancelled">
                                            <div class="tracker-dot"><i class="fa fa-xmark" style="font-size:14px;"></i></div>
                                            <div class="tracker-label">Cancelled</div>
                                        </div>
                                    }
                                    else
                                    {
                                        var icons = new[] { "fa-clock", "fa-gear", "fa-truck-fast", "fa-circle-check" };
                                        var labels = new[] { "Pending", "Processing", "Shipped", "Delivered" };

                                        for (int i = 0; i < 4; i++)
                                        {
                                            var stepClass = "";
                                            if (i < currentStep) stepClass = "done";
                                            else if (i == currentStep) stepClass = "active";

                                            <div class="tracker-step @stepClass">
                                                <div class="tracker-dot">
                                                    @if (i < currentStep)
                                                    {
                                                        <i class="fa fa-check" style="font-size:12px;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa @icons[i]" style="font-size:12px;"></i>
                                                    }
                                                </div>
                                                <div class="tracker-label">@labels[i]</div>
                                            </div>

                                            @if (i < 3)
                                            {
                                                var fillWidth = "0%";
                                                if (i < currentStep) fillWidth = "100%";
                                                else if (i == currentStep) fillWidth = "50%";

                                                <div class="tracker-line-wrap">
                                                    <div class="tracker-line-fill" style="width:@fillWidth;"></div>
                                                </div>
                                            }
                                        }
                                    }
                                </div>

                                <!-- Items -->
                                <div class="order-card-body">
                                    @if (order.OrderItems != null)
                                    {
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <div class="order-item">
                                                @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                                {
                                                    <img src="@item.Product.ImageUrl" class="oi-img" alt="@item.Product.Name" />
                                                }
                                                else
                                                {
                                                    <div class="oi-placeholder"><i class="fa fa-box"></i></div>
                                                }
                                                <div>
                                                    <div class="oi-name">@(item.Product?.Name ?? "Product")</div>
                                                    <div class="oi-qty">Qty: @item.Quantity &#215; &#8377;@item.Price.ToString("N2")</div>
                                                </div>
                                                <div class="oi-price">&#8377;@((item.Price * item.Quantity).ToString("N2"))</div>
                                            </div>
                                        }
                                    }

                                    <div class="shipping-info">
                                        <span><i class="fa fa-user"></i> @order.FullName</span>
                                        <span><i class="fa fa-envelope"></i> @order.Email</span>
                                        <span><i class="fa fa-location-dot"></i> @order.Address</span>
                                    </div>
                                </div>

                                <!-- Footer -->
                                <div class="order-card-footer">
                                    <span class="order-items-count">
                                        <i class="fa fa-box-open me-1"></i>
                                        @(order.OrderItems?.Count ?? 0) item(s)
                                    </span>
                                    <div>
                                        <span class="order-total-label">Total: </span>
                                        <span class="order-total-value">&#8377;@order.TotalAmount.ToString("N2")</span>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                }
                else
                {
                    <div class="empty-box">
                        <i class="fa fa-box-open"></i>
                        <h5 class="fw-bold" style="color:#636e72;">No orders yet</h5>
                        <p style="color:#b2bec3;">Your order history will appear here after your first purchase.</p>
                        <a href="/Home/Products" class="btn-shop mt-2">
                            <i class="fa fa-shopping-bag me-1"></i> Start Shopping
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>
