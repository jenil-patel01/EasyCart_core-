@model eays.Models.Order
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

<style>
    .back-link {
        color: #667eea;
        font-weight: 600;
        text-decoration: none;
        font-size: 14px;
        transition: all .2s;
    }

    .back-link:hover { color: #764ba2; }

    .detail-section {
        background: #fff;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .detail-section h6 {
        font-weight: 700;
        font-size: 16px;
        color: #2d3436;
        margin-bottom: 16px;
    }

    .detail-section h6 i { color: #667eea; margin-right: 8px; }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .info-item-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
        color: #b2bec3;
        margin-bottom: 2px;
    }

    .info-item-value {
        font-size: 15px;
        font-weight: 600;
        color: #2d3436;
    }

    /* Status */
    .status-pill-lg {
        padding: 6px 18px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        display: inline-block;
    }

    .status-Pending    { background: #fdcb6e; color: #856404; }
    .status-Processing { background: #74b9ff; color: #0c5460; }
    .status-Shipped    { background: #a29bfe; }
    .status-Delivered  { background: #00b894; }
    .status-Cancelled  { background: #ff7675; }

    /* Items table */
    .items-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 6px;
    }

    .items-table thead th {
        background: #f8f9fa;
        padding: 10px 14px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #b2bec3;
        border: none;
    }

    .items-table thead th:first-child { border-radius: 8px 0 0 8px; }
    .items-table thead th:last-child  { border-radius: 0 8px 8px 0; }

    .items-table tbody td {
        padding: 12px 14px;
        vertical-align: middle;
        background: #fff;
        border-top: 1px solid #f1f2f6;
        border-bottom: 1px solid #f1f2f6;
    }

    .items-table tbody td:first-child { border-left: 1px solid #f1f2f6; border-radius: 8px 0 0 8px; }
    .items-table tbody td:last-child  { border-right: 1px solid #f1f2f6; border-radius: 0 8px 8px 0; }

    .items-table tbody tr {
        box-shadow: 0 1px 6px rgba(0,0,0,0.03);
    }

    .item-img {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        border: 2px solid #f1f2f6;
    }

    .item-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        background: #f1f2f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        color: #b2bec3;
    }

    .item-subtotal { font-weight: 700; color: #00b894; }

    /* Status Update */
    .status-form {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .status-form select {
        border-radius: 10px;
        padding: 8px 16px;
        border: 2px solid #f1f2f6;
        font-weight: 600;
        font-size: 14px;
        min-width: 180px;
    }

    .status-form select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102,126,234,.12);
        outline: none;
    }

    .btn-update {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 8px 22px;
        font-weight: 700;
        font-size: 14px;
        transition: all .2s;
        cursor: pointer;
    }

    .btn-update:hover {
        box-shadow: 0 6px 18px rgba(102,126,234,.35);
        transform: translateY(-2px);
    }

    .btn-delete {
        background: #ff7675;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 8px 22px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-delete:hover {
        background: #d63031;
        box-shadow: 0 6px 18px rgba(214,48,49,.3);
    }

    .total-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #667eea08, #764ba210);
        border-radius: 10px;
        padding: 14px 18px;
        margin-top: 12px;
    }

    .total-bar span { font-weight: 700; color: #2d3436; }
    .total-bar strong { font-weight: 800; font-size: 20px; color: #00b894; }

    .order-id-lg {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        padding: 6px 18px;
        border-radius: 10px;
        font-weight: 800;
        font-size: 16px;
    }
</style>

<a href="/Admin/Orders" class="back-link mb-3 d-inline-block">
    <i class="fa fa-arrow-left me-1"></i> Back to Orders
</a>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        <h2 class="fw-bold mb-0">Order Detail</h2>
        <span class="order-id-lg">#@Model.Id</span>
        <span class="status-pill-lg status-@Model.Status">@Model.Status</span>
    </div>
</div>

@if (TempData["OrderMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert"
         style="border-radius:10px; border:none; font-weight:600;">
        <i class="fa fa-check-circle me-1"></i> @TempData["OrderMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    <!-- LEFT: Customer Info + Status -->
    <div class="col-md-5">

        <!-- Customer Info -->
        <div class="detail-section mb-4">
            <h6><i class="fa fa-user"></i> Customer Information</h6>
            <div class="info-grid">
                <div>
                    <div class="info-item-label">Full Name</div>
                    <div class="info-item-value">@Model.FullName</div>
                </div>
                <div>
                    <div class="info-item-label">Email</div>
                    <div class="info-item-value">@Model.Email</div>
                </div>
                <div>
                    <div class="info-item-label">Address</div>
                    <div class="info-item-value">@Model.Address</div>
                </div>
                <div>
                    <div class="info-item-label">Order Date</div>
                    <div class="info-item-value">@Model.OrderDate.ToString("MMM dd, yyyy — hh:mm tt")</div>
                </div>
            </div>
        </div>

        <!-- Update Status -->
        <div class="detail-section mb-4">
            <h6><i class="fa fa-arrows-rotate"></i> Update Status</h6>
            <form asp-action="UpdateOrderStatus" method="post" class="status-form">
                <input type="hidden" name="id" value="@Model.Id" />
                <select name="status" class="form-select">
                    <option value="Pending" selected="@(Model.Status == "Pending")">?? Pending</option>
                    <option value="Processing" selected="@(Model.Status == "Processing")">?? Processing</option>
                    <option value="Shipped" selected="@(Model.Status == "Shipped")">?? Shipped</option>
                    <option value="Delivered" selected="@(Model.Status == "Delivered")">? Delivered</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">? Cancelled</option>
                </select>
                <button type="submit" class="btn-update">
                    <i class="fa fa-save me-1"></i> Update
                </button>
            </form>
        </div>

        <!-- Delete -->
        <div class="detail-section">
            <h6><i class="fa fa-triangle-exclamation" style="color:#ff7675;"></i> Danger Zone</h6>
            <p style="font-size:13px; color:#636e72;">Permanently delete this order and all its items.</p>
            <form asp-action="DeleteOrder" method="post"
                  onsubmit="return confirm('Are you sure you want to delete order #@Model.Id? This cannot be undone.')">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn-delete">
                    <i class="fa fa-trash me-1"></i> Delete Order
                </button>
            </form>
        </div>
    </div>

    <!-- RIGHT: Items -->
    <div class="col-md-7">
        <div class="detail-section">
            <h6><i class="fa fa-box-open"></i> Ordered Items (@(Model.OrderItems?.Count ?? 0))</h6>

            <table class="items-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderItems != null)
                    {
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" class="item-img" alt="@item.Product.Name" />
                                    }
                                    else
                                    {
                                        <div class="item-placeholder"><i class="fa fa-box"></i></div>
                                    }
                                </td>
                                <td><strong>@(item.Product?.Name ?? "Product")</strong></td>
                                <td>$@item.Price.ToString("N2")</td>
                                <td>@item.Quantity</td>
                                <td class="item-subtotal">$@((item.Price * item.Quantity).ToString("N2"))</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="total-bar">
                <span>Order Total</span>
                <strong>$@Model.TotalAmount.ToString("N2")</strong>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Pre-select current status in dropdown
    (function () {
        var currentStatus = '@Model.Status';
        var select = document.querySelector('select[name="status"]');
        if (select) {
            for (var i = 0; i < select.options.length; i++) {
                if (select.options[i].value === currentStatus) {
                    select.selectedIndex = i;
                    break;
                }
            }
        }
    })();
</script>
