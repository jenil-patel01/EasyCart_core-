@model List<eays.Models.ApplicationUser>
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="page-header">
    <h2>Users</h2>

    
</div>

<div class="card-table">

    <div class="table-header">
        <h3>All Users</h3>
    </div>

    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Address</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @{
                int i = 1;
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td>@i</td>
                   
                    <td>@u.FullName</td>
                    <td>@u.Email</td>
                    <td>@u.Address</td>

                    <td class="text-end" >
                       

                        <a href="/Admin/DeleteUser/@u.Id" class="btn-del">
                            Delete
                        </a>
                    </td>
                </tr>
                i++;
            }
        </tbody>
    </table>
</div>