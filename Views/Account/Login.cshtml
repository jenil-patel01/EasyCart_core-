@model eays.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            background: #99ccff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: #fff;
            padding: 60px 55px; /* more inner space */
            border-radius: 18px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            width: 520px; /* bigger width */
        }

        .welcome {
            font-size: 12px;
            color: #999;
        }

        .title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 25px;
        }

        .form-control {
            border-radius: 10px;
            background: #f7f3f2;
            border: none;
            height: 48px;
            font-size: 14px;
        }
        .form-label {
            font-size: 12px;
            color: #666;
            margin-bottom: 4px;
        }

        .btn-login {
            background: #4da6ff;
            border: none;
            border-radius: 20px;
            padding: 10px;
            color: white;
            font-weight: 500;
            width: 120px;
            margin: 15px auto;
            display: block;
        }

            .btn-login:hover {
                background: #e85c32;
            }

        .forgot {
            font-size: 11px;
            float: right;
            color: #999;
            text-decoration: none;
        }

        .signup {
            font-size: 12px;
            text-align: center;
            margin-top: 20px;
            color: #999;
        }

            .signup a {
                color: #ff6a3d;
                text-decoration: none;
                font-weight: 500;
            }
    </style>
</head>

<body>
    <div class="login-card">
        <div class="welcome">Welcome back !!!</div>
        <div class="title">Sign in</div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="test@gmail.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-2">
                <label asp-for="Password" class="form-label">Password</label>
                <a href="#" class="forgot">Forgot Password ?</a>
                <input asp-for="Password" type="password" class="form-control" placeholder="********" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">SIGN IN ?</button>

            <div class="signup">
                I don't have an account ? <a href="/Account/Register">Sign up</a>
            </div>
        </form>
    </div>
</body>
</html>