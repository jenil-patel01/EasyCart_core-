@model eays.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <!-- Header -->
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h2 class="checkout-title"><i class="fa fa-lock"></i> Secure Checkout</h2>
                    <a href="/Cart" class="btn-back"><i class="fa fa-arrow-left me-1"></i> Back to Cart</a>
                </div>

                <!-- Steps -->
                <div class="checkout-steps">
                    <div class="step done">
                        <span class="step-num"><i class="fa fa-check"></i></span> Cart
                    </div>
                    <div class="step-line" style="background:#00b894;"></div>
                    <div class="step active">
                        <span class="step-num">2</span> Checkout
                    </div>
                    <div class="step-line"></div>
                    <div class="step">
                        <span class="step-num">3</span> Confirmation
                    </div>
                </div>

                <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" class="ck-form">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">

                        <!-- LEFT: Billing Details -->
                        <div class="col-lg-7">
                            <div class="ck-card">
                                <h5><i class="fa fa-file-invoice"></i> Billing Details</h5>

                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label">Full Name</label>
                                        <div class="input-icon-wrap">
                                            <i class="fa fa-user"></i>
                                            <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                                        </div>
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Email Address</label>
                                        <div class="input-icon-wrap">
                                            <i class="fa fa-envelope"></i>
                                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Phone (optional)</label>
                                        <div class="input-icon-wrap">
                                            <i class="fa fa-phone"></i>
                                            <input type="text" class="form-control" placeholder="+1 234 567 8900" />
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Shipping Address</label>
                                        <div class="input-icon-wrap">
                                            <i class="fa fa-location-dot"></i>
                                            <input asp-for="Address" class="form-control" placeholder="Full address" />
                                        </div>
                                        <span asp-validation-for="Address" class="text-danger"></span>
                                    </div>
                                </div>

                                
                            </div>
                        </div>

                        <!-- RIGHT: Order Summary -->
                        <div class="col-lg-5">
                            <div class="ck-card">
                                <h5><i class="fa fa-bag-shopping"></i> Order Summary</h5>

                                @foreach (var item in Model.CartItems)
                                {
                                    <div class="cart-item-row">
                                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" class="cart-item-img"
                                                 alt="@item.Product.Name" />
                                        }
                                        else
                                        {
                                            <div class="cart-item-img-placeholder">
                                                <i class="fa fa-box"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="cart-item-name">@item.Product?.Name</div>
                                            <div class="cart-item-qty">Qty: @item.Quantity &#215; &#8377;@item.Product?.Price.ToString("N2")</div>
                                        </div>
                                        <div class="cart-item-price">
                                            &#8377;@((item.Product?.Price ?? 0 * item.Quantity).ToString("N2"))
                                        </div>
                                    </div>
                                }

                                <div class="mt-3">
                                    <div class="summary-row">
                                        <span>Subtotal (@Model.CartItems.Count items)</span>
                                        <span>&#8377;@Model.Total.ToString("N2")</span>
                                    </div>
                                    <div class="summary-row">
                                        <span>Shipping</span>
                                        <span style="color:#00b894; font-weight:600;">FREE</span>
                                    </div>
                                    <div class="summary-row">
                                        <span>Tax</span>
                                        <span>&#8377;0.00</span>
                                    </div>
                                    <div class="summary-row total">
                                        <span>Total</span>
                                        <span class="summary-val">&#8377;@Model.Total.ToString("N2")</span>
                                    </div>
                                   
                                </div>

                                <button type="submit" class="btn-place-order mt-3" id="placeOrderBtn">
                                    <i class="fa fa-lock me-2"></i> Place Order &#8212; &#8377;@Model.Total.ToString("N2")
                                </button>

                                <div class="text-center mt-3">
                                    <small style="color:#b2bec3;">
                                        <i class="fa fa-shield-check me-1"></i> Safe & Secure Checkout
                                    </small>
                                </div>
                            </div>
                        </div>

                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Disable button on submit to prevent double-click
        document.querySelector('.ck-form')?.addEventListener('submit', function () {
            var btn = document.getElementById('placeOrderBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i> Processing...';
        });
    </script>
}
