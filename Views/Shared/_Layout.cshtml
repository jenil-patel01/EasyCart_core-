<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyCart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/eays.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        /* ===== PROFILE AVATAR IN NAVBAR ===== */
        .nav-profile-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
            border: 2px solid #e0d4f7;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        .nav-profile-avatar:hover {
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.25);
            transform: scale(1.08);
        }

        .nav-profile-dropdown .dropdown-toggle::after {
            display: none;
        }

        .nav-profile-dropdown .dropdown-menu {
            border: none;
            border-radius: 14px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
            padding: 10px 0;
            min-width: 220px;
            margin-top: 10px !important;
            animation: dropFade 0.2s ease;
        }

        @@keyframes dropFade {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .nav-profile-dropdown .dropdown-header {
            padding: 12px 18px;
            border-bottom: 1px solid #f1f2f6;
        }

        .nav-profile-dropdown .dropdown-header .profile-name {
            font-weight: 700;
            font-size: 15px;
            color: #2d3436;
        }

        .nav-profile-dropdown .dropdown-header .profile-email {
            font-size: 12px;
            color: #b2bec3;
        }

        .nav-profile-dropdown .dropdown-item {
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            color: #636e72;
            transition: all 0.15s;
        }

        .nav-profile-dropdown .dropdown-item i {
            width: 22px;
            text-align: center;
            margin-right: 8px;
            font-size: 14px;
        }

        .nav-profile-dropdown .dropdown-item:hover {
            background: linear-gradient(135deg, #667eea10, #764ba210);
            color: #667eea;
        }

        .nav-profile-dropdown .dropdown-item.text-danger:hover {
            background: #fff5f5;
            color: #e84393;
        }

        .nav-profile-dropdown .dropdown-divider {
            margin: 4px 0;
            border-color: #f1f2f6;
        }

        /* ===== AUTH BUTTONS (not logged in) ===== */
        .btn-nav-login {
            border: 2px solid #667eea;
            color: #667eea;
            border-radius: 10px;
            padding: 6px 18px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-nav-login:hover {
            background: #667eea;
            color: #fff;
        }

        .btn-nav-register {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 7px 18px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-nav-register:hover {
            box-shadow: 0 6px 18px rgba(102, 126, 234, 0.35);
            color: #fff;
            transform: translateY(-1px);
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- ===== HEADER ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold" href="/">🛒 EasyCart</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">

                    <!-- Left -->
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/About">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Products">Products</a></li>
                    </ul>

                    <!-- Right -->
                    <ul class="navbar-nav align-items-lg-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" href="/orders">
                                <i class="fa fa-box me-1"></i> My Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                                <i class="fa fa-heart me-1" style="color:#e84393;"></i> Wishlist (@(ViewBag.WishlistCount ?? 0))
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa fa-cart-shopping me-1" style="color:#667eea;"></i> Cart (@(ViewBag.CartCount ?? 0))
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- PROFILE AVATAR DROPDOWN -->
                            <li class="nav-item dropdown nav-profile-dropdown ms-lg-2">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 p-0"
                                   href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="nav-profile-avatar">
                                        @(User.Identity.Name != null && User.Identity.Name.Length > 0
                                            ? User.Identity.Name[0].ToString().ToUpper()
                                            : "U")
                                    </span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <div class="dropdown-header">
                                            <div class="profile-name">@User.Identity.Name</div>
                                            <div class="profile-email">Signed in</div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fa fa-user"></i> My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/orders">
                                            <i class="fa fa-bag-shopping"></i> My Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Wishlist" asp-action="Index">
                                            <i class="fa fa-heart"></i> Wishlist
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="fa fa-right-from-bracket"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="btn-nav-login" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-nav-register" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function setCartCount(count) {
            const el = document.getElementById('cart-count');
            if (el) el.textContent = count;
        }

        (function () {
            var success = '@(TempData["SuccessMessage"] ?? "")';
            if (success) {
                alert(success);
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>