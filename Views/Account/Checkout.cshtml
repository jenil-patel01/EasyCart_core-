@model eays.Models.CheckoutViewModel


<h2>Checkout</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Your Cart</h4>
        <table class="table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        <td>@item.Product.Name</td>
                        <td>₹ @item.Product.Price</td>
                        <td>@item.Quantity</td>
                        <td>₹ @(item.Product.Price* item.Quantity)</td>
                    </tr>
                }
            </tbody>
        </table>

        <h4 class="text-end">Total: ₹ @Model.Total</h4>
    </div>

    <div class="col-md-6">
        <h4>Billing Details</h4>

        <form asp-action="PlaceOrder" method="post">
            <div class="mb-2">
                <label>Full Name</label>
                <input asp-for="FullName" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Email</label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Address</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success mt-3 w-100">
                Place Order
            </button>
        </form>
    </div>
</div>